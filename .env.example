# =============================================================================
# CORIS — variabili ambiente (fase 0)
# Copia in .env:  cp .env.example .env
# Avvio DB:      docker compose up -d postgres
# =============================================================================

# --- PostgreSQL (servizio attivo in fase 0) ---
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_USER=coris
POSTGRES_PASSWORD=coris_dev_password_change_me
POSTGRES_DB=coris
POSTGRES_PORT=5432

# --- API Gateway (fase 1, placeholder) ---
API_GATEWAY_PORT=3000
API_GATEWAY_URL=http://localhost:3000

# --- ML Service (fase 1, placeholder) ---
ML_SERVICE_PORT=8000
ML_SERVICE_URL=http://localhost:8000

# --- Frontend (fase 1, placeholder) ---
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# --- Keycloak (fase 2, placeholder) ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password_change_me
